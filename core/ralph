#!/bin/bash
# Ralph Loop v3.1 - Shell Wrapper
# 调用 Python 实现，解决中文编码问题

# 设置 UTF-8 环境
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"
export PYTHONIOENCODING="utf-8"

# 获取脚本所在目录（处理符号链接）
# 如果是符号链接，获取指向的实际文件所在目录
if [ -L "$0" ]; then
    SCRIPT_DIR="$(cd "$(dirname "$(readlink "$0")")" && pwd)"
else
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
fi
PYTHON_SCRIPT="$SCRIPT_DIR/ralph.py"
RALPH_DIR="$(dirname "$SCRIPT_DIR")"

# 检查 Python 脚本是否存在
if [ ! -f "$PYTHON_SCRIPT" ]; then
    echo "错误: 找不到 Python 脚本: $PYTHON_SCRIPT"
    exit 1
fi

# 检查 Python 3 是否可用
if command -v python3 &> /dev/null; then
    PYTHON=python3
elif command -v python &> /dev/null; then
    PYTHON=python
else
    echo "错误: 需要 Python 3"
    exit 1
fi

# 调用 Python 脚本
exec $PYTHON "$PYTHON_SCRIPT" "$@"
